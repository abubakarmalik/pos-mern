generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @unique
  description String?
  is_active   Boolean?   @default(true)
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?  @db.Timestamptz(6)
  products    products[]

  @@index([name])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  sku           String         @unique
  barcode       String?
  category_id   String?        @db.Uuid
  unit          String
  cost_price    Decimal        @default(0) @db.Decimal(12, 2)
  sale_price    Decimal        @default(0) @db.Decimal(12, 2)
  tax_rate      Decimal?       @default(0) @db.Decimal(5, 2)
  stock_on_hand Decimal?       @default(0) @db.Decimal(12, 2)
  min_stock     Decimal?       @default(0) @db.Decimal(12, 2)
  is_active     Boolean?       @default(true)
  created_at    DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?      @db.Timestamptz(6)
  categories    categories?    @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  sale_items    sale_items[]
  stock_ledger  stock_ledger[]

  @@index([category_id], map: "products_category_idx")
  @@index([name])
  @@index([sku])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refunds {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sale_id       String    @db.Uuid
  reason        String?
  refund_amount Decimal   @default(0) @db.Decimal(12, 2)
  created_by    String?   @db.Uuid
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  users         users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales         sales     @relation(fields: [sale_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sale_id], map: "refunds_sale_idx")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sale_items {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sale_id             String    @db.Uuid
  product_id          String?   @db.Uuid
  name_snapshot       String
  sku_snapshot        String?
  unit_snapshot       String?
  qty                 Decimal   @db.Decimal(12, 2)
  cost_price_snapshot Decimal   @default(0) @db.Decimal(12, 2)
  sale_price_snapshot Decimal   @default(0) @db.Decimal(12, 2)
  tax_rate_snapshot   Decimal?  @default(0) @db.Decimal(5, 2)
  line_discount       Decimal?  @default(0) @db.Decimal(12, 2)
  line_subtotal       Decimal?  @default(0) @db.Decimal(12, 2)
  tax                 Decimal?  @default(0) @db.Decimal(12, 2)
  line_total          Decimal   @default(0) @db.Decimal(12, 2)
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  products            products? @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  sales               sales     @relation(fields: [sale_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "sale_items_product_idx")
  @@index([sale_id], map: "sale_items_sale_idx")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sales {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_no          String         @unique
  cashier_id          String         @db.Uuid
  subtotal            Decimal        @default(0) @db.Decimal(12, 2)
  line_discount_total Decimal?       @default(0) @db.Decimal(12, 2)
  cart_discount       Decimal?       @default(0) @db.Decimal(12, 2)
  discount_total      Decimal?       @default(0) @db.Decimal(12, 2)
  tax_total           Decimal?       @default(0) @db.Decimal(12, 2)
  total               Decimal        @default(0) @db.Decimal(12, 2)
  payment_method      payment_method
  cash_received       Decimal?       @db.Decimal(12, 2)
  change_due          Decimal?       @db.Decimal(12, 2)
  status              sale_status?   @default(COMPLETED)
  created_at          DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?      @db.Timestamptz(6)
  refunds             refunds[]
  sale_items          sale_items[]
  users               users          @relation(fields: [cashier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cashier_id], map: "sales_cashier_idx")
  @@index([created_at])
  @@index([invoice_no], map: "sales_invoice_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model settings {
  id                   Int       @id @default(1)
  shop_name            String
  address              String?
  phone                String?
  currency_symbol      String?   @default("Rs.")
  allow_negative_stock Boolean?  @default(false)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model stock_ledger {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id    String              @db.Uuid
  type          stock_movement_type
  qty_change    Decimal             @db.Decimal(12, 2)
  balance_after Decimal?            @db.Decimal(12, 2)
  ref_type      String?
  ref_id        String?             @db.Uuid
  note          String?
  created_by    String?             @db.Uuid
  created_at    DateTime?           @default(now()) @db.Timestamptz(6)
  users         users?              @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products      products            @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at])
  @@index([product_id], map: "stock_ledger_product_idx")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  username      String         @unique
  password_hash String
  role          user_role      @default(CASHIER)
  is_active     Boolean?       @default(true)
  created_at    DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?      @db.Timestamptz(6)
  refunds       refunds[]
  sales         sales[]
  stock_ledger  stock_ledger[]

  @@index([created_at])
  @@index([role])
}

enum payment_method {
  CASH
  CARD
  BANK
  JAZZCASH
  EASYPAISA
}

enum sale_status {
  COMPLETED
  REFUNDED
  VOID
}

enum stock_movement_type {
  SALE
  PURCHASE
  REFUND
  ADJUSTMENT
}

enum user_role {
  ADMIN
  CASHIER
}
